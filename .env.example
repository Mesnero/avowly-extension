# Public env vars (compiled into the extension bundle, do NOT put secrets here).
# wxt forwards WXT_PUBLIC_* and VITE_* into the extension at build time.

# Avowly API base URL
WXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Clerk Publishable Key (for extension auth)
WXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Clerk Sync Host — the URL of your web app where users sign in.
# The extension mirrors the Clerk session from this host automatically,
# so users don't need a separate login inside the extension popup.
# In development this is your local Next.js dashboard; in production
# it should be your public dashboard URL (e.g. https://app.avowly.com).
WXT_PUBLIC_CLERK_SYNC_HOST=http://localhost:3001

# Build-time toggle for verbose logging in the content scripts.
WXT_PUBLIC_DEBUG=false
